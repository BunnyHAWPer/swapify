# Swapify backend environment variables
# Copy this file to `.env` and fill in your real values.

# --- Deployment / server (Task 1 & 4) ----------------------------------------
# Host and port to bind. On a PaaS (Render/Railway) PORT is injected for you and
# HOST should be 0.0.0.0. Locally the defaults (127.0.0.1:8000) are fine.
# HOST=0.0.0.0
# PORT=8000
# Disable the autoreloader in production.
# RELOAD=false
# Comma-separated allowed CORS origins in production (e.g. your frontend URL).
# Defaults to "*" for local development.
# CORS_ORIGINS=https://your-frontend.example.com
# Origins matched by regex *in addition* to CORS_ORIGINS. The default already
# covers localhost and hybrid mobile shells (capacitor://, ionic://), so locking
# CORS_ORIGINS to your web frontend will not break the phone build. Override only
# if your mobile client uses some other custom scheme.
# CORS_ORIGIN_REGEX=^(https?://localhost(:\d+)?|capacitor://localhost)$
# Absolute path to the SQLite database (point at a persistent disk in prod).
# DATABASE_PATH is accepted as an alias.
# SWAPIFY_DB_PATH=/var/data/swapify.db
# Path to the catalogue CSV used to seed / sync the database.
# SWAPIFY_CSV_PATH=/app/server/products.csv
# Seconds a query waits for a concurrent writer before giving up. Matters when
# several gunicorn workers share one SQLite file (default 15).
# SQLITE_BUSY_TIMEOUT=15
# Strong random JWT signing key for production (falls back to a dev default).
# SECRET_KEY=change-me-to-a-long-random-string

# --- Experiment logging admin access (Task 3) --------------------------------
# Shared secret required to read GET /experiment/logs and /experiment/analytics,
# sent by the client as the `X-Admin-Token` header. If unset, the app falls back
# to the dev token "swapify-admin-dev" and logs a warning at startup — always set
# a strong value in production.
# ADMIN_TOKEN=change-me-to-a-long-random-string
# Optional: comma-separated emails of registered users who count as admins. They
# can read the logs with an ordinary JWT from /login, no shared secret needed.
# ADMIN_EMAILS=you@example.com

# --- OCR Label Scanner POC (Task 6) ------------------------------------------
# Path to the Tesseract binary if it is not already on PATH (common on Windows,
# e.g. C:\Program Files\Tesseract-OCR\tesseract.exe). The /ocr/* endpoints need
# the Tesseract engine plus pytesseract + Pillow (see requirements.txt).
# TESSERACT_CMD=

# --- AI Nutritionist (/chat) -------------------------------------------------
# OpenRouter API key. Get a free one at https://openrouter.ai/keys
# OpenRouter exposes many models through one OpenAI-compatible API, including
# free-tier models, so the AI nutritionist costs nothing to run.
# If left blank, the /chat endpoint still works using a deterministic,
# food-science fallback (including ingredient substitutions; no external call).
OPENROUTER_API_KEY=

# Model to use (optional; defaults to a free instruct model).
# Any free OpenRouter model works. Pick one that returns normal message content
# (some "reasoning" free models emit only a hidden trace).
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Optional comma-separated fallback models, tried in order if the primary model
# is offline or rate-limited (free models often are). Keeps /chat on the AI
# path instead of dropping to the rule-based answer. Example:
# OPENROUTER_FALLBACK_MODELS=openai/gpt-oss-20b:free, meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FALLBACK_MODELS=

# --- Optional second AI provider: Google Gemini ------------------------------
# When set, Gemini is used as an automatic failover after OpenRouter, so the
# chatbot keeps giving real AI answers even if every OpenRouter free model is
# rate-limited. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Error tracking: Sentry (Task 2) -----------------------------------------
# Leave SENTRY_DSN blank to disable error tracking entirely — the app runs
# normally, errors just go to the logs only. This is the expected local-dev state.
#
# Setup:
#   1. Create a free account at https://sentry.io (Developer plan, no card).
#   2. Create a project, platform "FastAPI". Sentry shows you a DSN that looks
#      like: https://<key>@o<org>.ingest.sentry.io/<project>
#   3. Paste it below locally, and set it as an environment variable on Render
#      (Dashboard -> your service -> Environment). Never commit a real DSN.
#   4. Verify: POST /debug/sentry-test with the X-Admin-Token header. It raises a
#      real 500 on purpose; the event should appear in Sentry within seconds.
#      GET /health reports "error_tracking": "sentry" when it is live.
#
# The DSN is a write-only ingest key, not a secret that grants account access —
# but keep it out of git regardless.
SENTRY_DSN=

# "production" / "staging" / "development" — segregates issues in the Sentry UI.
SENTRY_ENVIRONMENT=development

# Optional release identifier (e.g. a git sha) so Sentry can tell you which
# deploy introduced a regression.
SENTRY_RELEASE=

# Performance-trace sampling, 0.0-1.0. Keep at 0 on the free tier: traces burn
# quota fast and error tracking is what we actually need.
SENTRY_TRACES_SAMPLE_RATE=0
